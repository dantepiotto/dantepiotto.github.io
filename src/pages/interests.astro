---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About me">
    <h1>About me</h1>
    <p></p>

    <div class="grid">

        <div class="card">
            <h3>ITER Organization</h3>
            <p>
            Internship within the Science Division
            </p>
            <ul>
                <li>Developed dynamic models and physics based control algorithms for the ITER Gas Injection System</li>
                <li>Integrated models and control within the ITER simulation framework in Matlab/Simulink and produced documentation</li>
                <li>Presented and discussed results of my work in Science Division meetings</li>
            </ul>
            <div>
                <span class="tag">Multiphysics Modelling</span>
                <span class="tag">Non-linear Control</span>
                <span class="tag">Matlab</span>
                <span class="tag">Simulink</span>
                <span class="tag">Python</span>
            </div>
            <img src="/imgs/iter.jpeg" alt="ITER Intern group">
        </div>
    </div>

    <div class="grid">

        <div class="card">
            <h3>Leonardo Drone Contest</h3>
            <p>
            Internship at University of Bologna
            </p>
            <ul>
                <li>Took part in an autonomous robotics competition sponsored by Leonardo</li>
                <li>Developed algorithms for autonomous exploration and target search missions in unexplored environments</li>
                <li>Worked with a heterogeneous pair of autonomus vehicles (rover and quadcopter)</li>
            </ul>
            <div>
                <span class="tag">Mobile Robotics</span>
                <span class="tag">SLAM</span>
                <span class="tag">Autonomus Navigation</span>
                <span class="tag">Python</span>
                <span class="tag">C++</span>
                <span class="tag">ROS2</span>
                <span class="tag">Gazebo</span>
            </div>
            <img src="/imgs/leonardo.jpeg" alt="Leonardo Drone Contest Arena">
        </div>
    </div>
</Layout>
